{
  "name": "planning-poker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "build:assets": "vite build",
    "check": "biome check .",
    "db:migrate": "bun src/scripts/migrate.ts",
    "dev": "bun run build:assets && bun --hot src/index.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "screenshots:pr": "bun src/scripts/screenshots-pr.ts",
    "start": "bun src/index.ts",
    "test": "bun test src",
    "test:a11y": "bun src/scripts/test-a11y.ts",
    "test:e2e": "bun run build && bunx playwright test",
    "typecheck": "tsc --noEmit",
    "verify": "bun run check && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@macavitymadcap/hyper-dank-automation": "^0.4.0",
    "@macavitymadcap/hyper-dank-data": "^0.4.0",
    "@macavitymadcap/hyper-dank-transport": "^0.4.0",
    "@macavitymadcap/hyper-dank-ui": "^0.4.0",
    "hono": "^4.0.0",
    "htmx.org": "^2.0.10",
    "open-props": "^1.7.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "pa11y": "^9.1.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.13"
  }
}
